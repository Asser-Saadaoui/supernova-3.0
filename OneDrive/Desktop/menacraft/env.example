# Server
PORT=3000

# AI microservice URLs
AUTHENTICITY_SERVICE_URL=http://localhost:5001/predict
CONTEXT_SERVICE_URL=http://localhost:5002/predict

# Aggregate scoring weights (must sum to 1.0)
WEIGHT_AUTHENTICITY=0.6
WEIGHT_CONTEXT=0.4

# Verdict thresholds
VERDICT_HIGH=0.7   # score >= this → likely_authentic
VERDICT_LOW=0.4    # score <  this → likely_inauthentic
